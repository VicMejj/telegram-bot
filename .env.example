# ---------------------------------------------------------------------------
# .env.example
# Copy this file to ".env" and fill in your real values.
# Never commit your real .env file to version control.
# ---------------------------------------------------------------------------

# --- Telegram ---------------------------------------------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# The chat ID (user, group, or channel) that should receive alerts
TELEGRAM_CHAT_ID=yourChatIDHere

# --- Binance ------------------------------------------------------------------
# Only symbols ending in this quote asset are scanned
QUOTE_ASSET=USDT

# --- Moving averages (configurable periods - do not hardcode elsewhere) ------
FAST_MA=7
MID_MA=25
SLOW_MA=99

# --- Strategy timeframe -------------------------------------------------------
# Only the last FULLY CLOSED candle of this timeframe is ever used for
# signals. Default is 1h.
TIMEFRAME=1h

# --- Scan / scoring settings ---------------------------------------------------
# Minimum score (0-100) required to trigger a Telegram alert
SCORE_THRESHOLD=75
# How often the scanner loops over all symbols, in seconds
SCAN_INTERVAL_SECONDS=1800
# Optional: limit how many symbols are scanned per loop (0 = no limit). Useful for testing.
MAX_SYMBOLS=0
# How many candles' worth of volume to average for the volume ratio
VOLUME_AVG_WINDOW=20
# Minimum volume ratio (current closed candle vs trailing average) to count as a surge
VOLUME_RATIO_MIN=2.0
# When enabled, the bot only allows alerts if MA7 > MA25 > MA99.
REQUIRE_MA_ALIGNMENT=1
# Hard-filter thresholds for the OI trend across 15m / 30m / 1h windows.
OI_15M_MIN_INCREASE_PCT=2.0
OI_30M_MIN_INCREASE_PCT=3.0
OI_1H_MIN_INCREASE_PCT=5.0
# Minimum open-interest increase (%) vs the previous reading to count as "OI rising"
OI_MIN_INCREASE_PCT=0.0
# How far (fraction) price can run above MA99 before being "overextended", e.g. 0.15 = 15%
MAX_EXTENSION_ABOVE_MA99=0.15

# --- Funding rate thresholds (decimal format: 0.0003 = 0.03%) -----------------
# Funding <= this is considered healthy for a long setup. Sign is never abs()'d -
# negative funding (shorts paying longs) is treated as extra bullish.
FUNDING_HEALTHY_THRESHOLD=0.0003
# Funding above this triggers a risk warning + score penalty
FUNDING_RISK_THRESHOLD=0.0005

# --- Alert cooldown -------------------------------------------------------------
# Minimum hours between two alerts for the SAME symbol
ALERT_COOLDOWN_HOURS=24

# --- Trend health / post-pullback monitoring ------------------------------------
# How often (hours) an already-alerted symbol is re-checked for pullback health
TREND_HEALTH_CHECK_INTERVAL_HOURS=4
# How many days after the original alert to keep monitoring it
TREND_HEALTH_MONITOR_WINDOW_DAYS=3
# Minimum pullback (%) from the alert price before pullback health is evaluated at all
MIN_PULLBACK_PCT_TO_EVALUATE=2.0
# trend_health_score (0-100) needed to send a "pullback healthy" Telegram update
TREND_HEALTH_UPDATE_THRESHOLD=70
# Minimum hours between two "still healthy" update alerts for the same original alert
TREND_HEALTH_UPDATE_COOLDOWN_HOURS=12

# --- Database ---------------------------------------------------------------------
DATABASE_PATH=database/crypto_edge_bot.db

# --- Historical learning --------------------------------------------------------
# Enable the simple history-based confidence boost from past alerts/outcomes.
HISTORY_LEARNING_ENABLED=1
HISTORY_LEARNING_MIN_SCORE=70
HISTORY_LEARNING_MIN_MATCHES=3
HISTORY_LEARNING_SCORE_TOLERANCE=10
HISTORY_LEARNING_MIN_SUCCESS_RATE=0.6
HISTORY_LEARNING_BONUS_MAX=5

# --- Logging -------------------------------------------------------------------------
# DEBUG, INFO, WARNING, or ERROR
LOG_LEVEL=INFO

# --- Networking ----------------------------------------------------------------------
# Delay (seconds) between each symbol's API calls, to stay within Binance's public rate limits
SYMBOL_SCAN_DELAY_SECONDS=0.3
